# Re:Earth CMS Integration — copy this file to .env and fill in your values
# .env is gitignored; never commit real tokens

# Re:Earth CMS base URL (no trailing slash)
VITE_CMS_BASE_URL=https://api.cms.reearth.io

# Re:Earth CMS project alias (e.g. "verified-crisis-mapper")
VITE_CMS_PROJECT=your-project-alias

# Re:Earth CMS model alias for damage reports (e.g. "damage-report")
VITE_CMS_MODEL=damage-report

# Re:Earth CMS API token (required for write operations: asset upload + item create)
# Create a token in CMS Settings > API Keys with write access to the project
VITE_CMS_TOKEN=

# Optional: leave VITE_CMS_TOKEN empty to make the dashboard read-only
# (dashboard fetches public CMS data; form submissions fall back to local-only mode)
